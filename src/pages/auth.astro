---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login or Register">
  <section class="brutal-section py-12 sm:py-20">
    <div class="max-w-lg mx-auto">

      <!-- Fun header -->
      <div class="text-center mb-8">
        <div class="inline-block bg-ink border-4 border-ink p-6 shadow-brutal-lg -rotate-2 mb-4 hover:rotate-0 transition-transform duration-300">
          <span class="text-6xl">🌿</span>
        </div>
        <div class="comic-caption inline-block mt-2">Join the surplus revolution!</div>
      </div>

      <div x-data="authComponent()" class="brutal-card bg-white overflow-hidden">

        <!-- Tab Switcher -->
        <div class="flex border-b-4 border-ink">
          <button @click="tab='login'"
            :class="tab==='login' ? 'bg-lime text-ink' : 'bg-white text-ink/50 hover:bg-cream'"
            class="flex-1 py-4 font-black text-lg uppercase tracking-wider transition-colors border-r-4 border-ink">
            🔑 Login
          </button>
          <button @click="tab='register'"
            :class="tab==='register' ? 'bg-yellow text-ink' : 'bg-white text-ink/50 hover:bg-cream'"
            class="flex-1 py-4 font-black text-lg uppercase tracking-wider transition-colors">
            ✍️ Register
          </button>
        </div>

        <!-- Error / Success alerts -->
        <div x-show="errorMsg" x-cloak class="mx-6 mt-5">
          <div class="bg-orange border-4 border-ink p-4 font-bold text-white text-sm shadow-brutal-sm -rotate-1">
            ⚠️ <span x-text="errorMsg"></span>
          </div>
        </div>
        <div x-show="successMsg" x-cloak class="mx-6 mt-5">
          <div class="bg-lime border-4 border-ink p-4 font-bold text-ink text-sm shadow-brutal-sm rotate-1">
            ✅ <span x-text="successMsg"></span>
          </div>
        </div>

        <!-- ── LOGIN ── -->
        <div x-show="tab==='login'" x-cloak class="p-6 sm:p-8">
          <h2 class="text-3xl font-black mb-1">Welcome back! 👋</h2>
          <p class="text-ink/60 text-sm mb-8">Sign in and continue saving the world.</p>

          <form @submit.prevent="handleLogin()" class="space-y-5">
            <div>
              <label class="block font-black text-sm uppercase tracking-wider mb-2">Email Address</label>
              <input x-model="loginEmail" type="email" required placeholder="you@example.com" class="brutal-input" />
            </div>
            <div>
              <label class="block font-black text-sm uppercase tracking-wider mb-2">Password</label>
              <input x-model="loginPassword" type="password" required placeholder="••••••••" class="brutal-input" />
            </div>
            <button type="submit" :disabled="loading"
              onclick="if(!this.disabled) navigateTo(event, '', '#ADFF2F')"
              @click.prevent="handleLogin()"
              class="brutal-btn w-full text-lg font-black" :class="loading?'opacity-60 cursor-wait':''">
              <span x-show="!loading">Sign In →</span>
              <span x-show="loading" x-cloak>Signing in... ⏳</span>
            </button>
          </form>

          <p class="text-center text-sm text-ink/60 mt-6">
            No account?
            <button @click="tab='register'" class="font-black text-ink underline underline-offset-2 hover:text-orange transition-colors bg-transparent border-none cursor-pointer">
              Register here
            </button>
          </p>
        </div>

        <!-- ── REGISTER ── -->
        <div x-show="tab==='register'" class="p-6 sm:p-8">
          <h2 class="text-3xl font-black mb-1">Join EcoShelf! 🚀</h2>
          <p class="text-ink/60 text-sm mb-8">Create your account and start making impact.</p>

          <form @submit.prevent="handleRegister()" class="space-y-5">
            <!-- User type cards -->
            <div>
              <label class="block font-black text-sm uppercase tracking-wider mb-3">I am a...</label>
              <div class="grid grid-cols-2 gap-4">
                <button type="button" @click="regUserType='retailer'"
                  :class="regUserType==='retailer'
                    ? 'bg-lime border-ink shadow-none translate-x-[3px] translate-y-[3px]'
                    : 'bg-white border-ink/30 hover:border-ink shadow-brutal-sm'"
                  class="p-5 border-4 text-center transition-all duration-150 cursor-pointer hover:animate-wobble">
                  <div class="text-4xl mb-2">🏪</div>
                  <div class="font-black text-sm">Retailer</div>
                  <div class="text-xs text-ink/60 mt-1">I have surplus</div>
                </button>
                <button type="button" @click="regUserType='ngo'"
                  :class="regUserType==='ngo'
                    ? 'bg-yellow border-ink shadow-none translate-x-[3px] translate-y-[3px]'
                    : 'bg-white border-ink/30 hover:border-ink shadow-brutal-sm'"
                  class="p-5 border-4 text-center transition-all duration-150 cursor-pointer hover:animate-wobble">
                  <div class="text-4xl mb-2">🤝</div>
                  <div class="font-black text-sm">NGO</div>
                  <div class="text-xs text-ink/60 mt-1">We rescue items</div>
                </button>
              </div>
            </div>

            <div>
              <label class="block font-black text-sm uppercase tracking-wider mb-2">Organization Name</label>
              <input x-model="regOrgName" type="text" required placeholder="Your org or business name" class="brutal-input" />
            </div>
            <div>
              <label class="block font-black text-sm uppercase tracking-wider mb-2">Email Address</label>
              <input x-model="regEmail" type="email" required placeholder="you@example.com" class="brutal-input" />
            </div>
            <div>
              <label class="block font-black text-sm uppercase tracking-wider mb-2">Password</label>
              <input x-model="regPassword" type="password" required minlength="6" placeholder="Min 6 characters" class="brutal-input" />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block font-black text-sm uppercase tracking-wider mb-2">Phone</label>
                <input x-model="regPhone" type="tel" placeholder="+1 555 0000" class="brutal-input" />
              </div>
              <div>
                <label class="block font-black text-sm uppercase tracking-wider mb-2">Address</label>
                <input x-model="regAddress" type="text" placeholder="123 Main St" class="brutal-input" />
              </div>
            </div>

            <button type="submit" :disabled="loading||!regUserType"
              class="w-full text-lg font-black"
              :class="[
                loading||!regUserType?'opacity-60 cursor-wait':'',
                regUserType==='ngo'?'brutal-btn-yellow':'brutal-btn'
              ]">
              <span x-show="!loading">
                Create Account as
                <span x-text="regUserType==='retailer'?'Retailer':regUserType==='ngo'?'NGO':'...'"></span> →
              </span>
              <span x-show="loading" x-cloak>Creating... ⏳</span>
            </button>
          </form>

          <p class="text-center text-sm text-ink/60 mt-6">
            Already registered?
            <button @click="tab='login'" class="font-black text-ink underline underline-offset-2 hover:text-orange transition-colors bg-transparent border-none cursor-pointer">
              Sign in here
            </button>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  function authComponent() {
    return {
      tab: 'login', loading: false, errorMsg: '', successMsg: '',
      loginEmail: '', loginPassword: '',
      regEmail: '', regPassword: '', regOrgName: '', regUserType: '', regPhone: '', regAddress: '',

      async handleLogin() {
        this.errorMsg=''; this.successMsg=''; this.loading=true;
        try {
          const { data, error } = await window.supa.auth.signInWithPassword({ email: this.loginEmail, password: this.loginPassword });
          if (error) { this.errorMsg=error.message; this.loading=false; return; }
          if (data.session) {
            this.successMsg='Login successful! Redirecting... 🚀';
            setTimeout(() => { sessionStorage.setItem('eco_transition_color','#ADFF2F'); window.location.href='/dashboard'; }, 800);
          }
        } catch(e) { this.errorMsg='Unexpected error. Try again.'; this.loading=false; }
      },

      async handleRegister() {
        this.errorMsg=''; this.successMsg='';
        if (!this.regUserType) { this.errorMsg='Please select Retailer or NGO! 👆'; return; }
        this.loading=true;
        try {
          const { data, error } = await window.supa.auth.signUp({ email: this.regEmail, password: this.regPassword });
          if (error) { this.errorMsg=error.message; this.loading=false; return; }
          if (data.user) {
            const { error: pe } = await window.supa.from('profiles').insert({ id: data.user.id, org_name: this.regOrgName, user_type: this.regUserType, phone: this.regPhone, address: this.regAddress });
            if (pe) { this.errorMsg='Profile error: '+pe.message; this.loading=false; return; }
            this.successMsg='Account created! Blasting off... 🚀';
            setTimeout(() => { sessionStorage.setItem('eco_transition_color','#FFD700'); window.location.href='/dashboard'; }, 1000);
          } else {
            this.successMsg='Check your email to confirm! 📧';
            this.loading=false;
          }
        } catch(e) { this.errorMsg='Unexpected error.'; this.loading=false; }
      },
    };
  }
</script>
