---
// Need Provider Project Update v2.1
import Layout from '../layouts/Layout.astro';
/* Browse page v2.1 — Polished spacing, refined visual hierarchy */
---

<Layout title="Contribution HUB">
  <section class="brutal-section py-10 sm:py-16">
    <div x-data="browseComponent()" x-init="init()">

      <!-- Page Header -->
      <div class="mb-12">
        <div class="comic-caption inline-block mb-4">Live Contribution Feed</div>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black mb-2">
          Contribution
          <span class="bg-lime px-2 py-1 inline-block -rotate-1">HUB</span>
        </h1>
        <p class="text-ink/50 font-medium text-lg leading-relaxed">
          Browse community resources. Claim what you need or donate surplus!
        </p>
      </div>

      <!-- Filter Bar -->
      <div class="brutal-card bg-white p-4 flex flex-wrap gap-3 mb-10">
        <template x-for="f in filters" :key="f.id">
          <button
            @click="activeCategory=f.id; fetchListings()"
            class="px-5 py-2.5 font-bold uppercase text-sm border-3 border-ink transition-all duration-150 hover:animate-wobble"
            :class="activeCategory===f.id
              ? 'translate-x-[2px] translate-y-[2px] shadow-none'
              : 'shadow-brutal-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-brutal-hover'"
            :style="activeCategory===f.id ? 'background:'+f.color : 'background:#ffffff'"
          >
            <span x-text="f.label"></span>
          </button>
        </template>
      </div>

      <!-- Result count -->
      <div class="flex items-center justify-between mb-6" x-show="!loading">
        <div class="brutal-badge bg-lime font-black">
          <span x-text="listings.length"></span> listing(s)
        </div>
        <div class="text-sm text-ink/60 font-semibold">
          Category: <span class="font-black text-ink" x-text="activeCategory==='all'?'All':activeCategory"></span>
        </div>
      </div>

      <!-- Loading -->
      <div x-show="loading" x-cloak class="text-center py-20">
        <div class="inline-block brutal-card bg-lime p-8 -rotate-3 animate-bounceIn">
          <div class="text-6xl mb-4 font-black">...</div>
          <p class="font-black text-xl">Fetching listings...</p>
        </div>
      </div>

      <!-- Listings Grid -->
      <div x-show="!loading && listings.length>0" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <template x-for="listing in listings" :key="listing.id">
          <div class="brutal-card bg-white flex flex-col overflow-hidden hover:-rotate-1 transition-transform duration-200">

            <!-- Color strip header -->
            <div class="px-4 py-3 border-b-4 border-ink font-black text-sm uppercase flex items-center justify-between"
              :style="'background:'+getCategoryColor(listing.category)">
              <span>
                <span x-text="listing.category"></span>
              </span>
              <!-- Countdown -->
              <span class="px-2 py-1 bg-white border-2 border-ink font-black text-xs"
                :class="getTimeLeft(listing.expiry_time).expired ? 'bg-orange text-white' : ''"
                x-text="getTimeLeft(listing.expiry_time).text">
              </span>
            </div>

            <div class="p-5 flex-1 flex flex-col">
              <h3 class="text-xl font-black mb-2" x-text="listing.title"></h3>
              <p class="text-ink/60 text-sm mb-4 flex-1 leading-relaxed"
                x-text="listing.description||'No description provided.'"></p>

              <div class="text-xs text-ink/40 mb-3 font-semibold" x-show="listing.profiles">
                Listed by: <span class="text-ink font-black" x-text="listing.profiles?.org_name||'Unknown'"></span>
              </div>

              <!-- Price box -->
              <div class="border-4 border-ink p-3 mb-4 bg-cream flex items-end gap-3">
                <div>
                  <div class="text-xs font-black uppercase text-ink/50">Original</div>
                  <div class="text-lg text-ink/40 line-through font-black">
                    $<span x-text="parseFloat(listing.original_price).toFixed(2)"></span>
                  </div>
                </div>
                <div>
                  <div class="text-xs font-black uppercase text-lime" style="color:#4d8a00">Surplus</div>
                  <div class="text-3xl font-black text-ink">
                    $<span x-text="parseFloat(listing.surplus_price).toFixed(2)"></span>
                  </div>
                </div>
                <div class="ml-auto">
                  <span class="brutal-badge bg-lime text-ink font-black text-base"
                    x-text="'-'+Math.round((1-listing.surplus_price/listing.original_price)*100)+'%'">
                  </span>
                </div>
              </div>

              <!-- Claim Button -->
              <button
                @click="claimListing(listing, $event)"
                :disabled="listing.status==='claimed'||getTimeLeft(listing.expiry_time).expired||claimingId===listing.id"
                class="w-full mt-auto font-black text-lg"
                :class="listing.status==='claimed'
                  ? 'brutal-btn opacity-50 cursor-not-allowed bg-gray-300'
                  : getTimeLeft(listing.expiry_time).expired
                    ? 'brutal-btn opacity-50 cursor-not-allowed bg-gray-300'
                    : claimingId===listing.id
                      ? 'brutal-btn-orange opacity-60 cursor-wait'
                      : 'brutal-btn-orange'"
              >
                <span x-show="listing.status==='claimed'">Already Claimed</span>
                <span x-show="listing.status!=='claimed'&&getTimeLeft(listing.expiry_time).expired">Expired</span>
                <span x-show="listing.status!=='claimed'&&!getTimeLeft(listing.expiry_time).expired&&claimingId!==listing.id">
                  Claim Resource
                </span>
                <span x-show="claimingId===listing.id" x-cloak>Claiming...</span>
              </button>
            </div>
          </div>
        </template>
      </div>

      <!-- Empty State -->
      <div x-show="!loading&&listings.length===0" x-cloak class="text-center py-20">
        <div class="inline-block brutal-card bg-cream p-12 hover:animate-wobble">
          <div class="text-6xl mb-6 font-black">Empty</div>
          <h3 class="text-2xl font-black mb-2">Nothing here... yet!</h3>
          <p class="text-ink/60 max-w-sm mx-auto mb-6">
            No available listings
            <span x-show="activeCategory!=='all'"> in <strong x-text="activeCategory"></strong></span>
            right now.
          </p>
          <button @click="activeCategory='all'; fetchListings()" class="brutal-btn">
            View All Categories
          </button>
        </div>
      </div>

      <!-- Claim Success Modal -->
      <div x-show="claimModal" x-cloak
        class="fixed inset-0 z-50 flex items-center justify-center p-4"
        style="background:rgba(13,13,13,0.7)"
        @click.self="claimModal=false">
        <div class="brutal-card bg-lime p-8 max-w-md w-full text-center -rotate-2 hover:rotate-0 transition-transform"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 scale-50 rotate-12"
          x-transition:enter-end="opacity-100 scale-100 -rotate-2">
          <h3 class="text-3xl font-black mb-2">CLAIMED!</h3>
          <p class="text-ink/70 mb-5 font-semibold">
            Show this verification token to the retailer when you collect.
          </p>
          <div class="bg-ink text-lime border-4 border-ink p-5 mb-6 font-black text-xl tracking-widest shadow-brutal-sm">
            <span x-text="claimToken"></span>
          </div>
          <button @click="claimModal=false" class="brutal-btn-black w-full text-lg font-black">
            Done! Let's go!
          </button>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script is:inline>
  function browseComponent() {
    return {
      activeCategory: 'all',
      listings: [], loading: true,
      claimingId: null, claimModal: false, claimToken: '',
      filters: [
        { id:'all',                    label:'All',                    color:'#0D0D0D', textColor:'#ADFF2F' },
        { id:'clothes',                label:'Clothes',                color:'#ADFF2F', textColor:'#0D0D0D' },
        { id:'shelter',                label:'Shelter',                color:'#FFD700', textColor:'#0D0D0D' },
        { id:'books',                  label:'Books',                  color:'#7DF9FF', textColor:'#0D0D0D' },
        { id:'educational_facilities', label:'Educational',            color:'#FF6EC7', textColor:'#0D0D0D' },
        { id:'food',                   label:'Food',                   color:'#FF9800', textColor:'#0D0D0D' },
      ],

      async init() {
        const params = new URLSearchParams(window.location.search);
        const cat = params.get('category');
        if (cat && ['clothes','shelter','books','educational_facilities','food'].includes(cat)) this.activeCategory = cat;
        await this.fetchListings();
      },

      async fetchListings() {
        this.loading = true;
        try {
          let url = '/listings?status=available';
          if (this.activeCategory !== 'all') url += '&category=' + this.activeCategory;
          const json = await window.apiFetch(url);
          this.listings = json.data || [];
        } catch(e) { this.listings=[]; }
        this.loading = false;
      },

      async claimListing(listing, event) {
        const user = await window.getUser();
        if (!user) { navigateTo(event, '/auth', '#FF6EC7'); return; }
        this.claimingId = listing.id;
        try {
          await window.apiFetch('/listings/' + listing.id + '/claim', { method: 'PATCH' });
          this.claimToken = 'NDP-'+listing.id.substring(0,8).toUpperCase()+'-'+Date.now().toString(36).toUpperCase();
          this.claimModal = true;
          listing.status = 'claimed';
        } catch(e) { alert('Failed: '+(e.message||'An error occurred.')); }
        this.claimingId = null;
      },

      getCategoryColor(cat) {
        return { clothes:'#ADFF2F', shelter:'#FFD700', books:'#7DF9FF', educational_facilities:'#FF6EC7', food:'#FF9800' }[cat]||'#E5E5E5';
      },
      getTimeLeft(t) {
        const diff = new Date(t)-new Date();
        if (diff<=0) return { text:'Expired', expired:true };
        const h=Math.floor(diff/3600000), m=Math.floor((diff%3600000)/60000);
        if (h>24) return { text:Math.floor(h/24)+'d '+(h%24)+'h left', expired:false };
        if (h>0) return { text:h+'h '+m+'m left', expired:false };
        return { text:m+'m left', expired:false };
      },
    };
  }
</script>
