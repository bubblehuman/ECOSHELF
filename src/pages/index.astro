<script is:inline>
  function counterBanner() {
    return {
      wasteDiverted: 0, activeListings: 0, businesses: 0,
      targetWaste: 12450, targetListings: 37, targetBusinesses: 86,
      async init() {
        try {
          const json = await window.apiFetch('/listings/count?status=available');
          if (json.count !== null && json.count !== undefined) this.targetListings = json.count;
        } catch(e) {}
        this.animateCounter('wasteDiverted', this.targetWaste, 2000);
        this.animateCounter('activeListings', this.targetListings, 1500);
        this.animateCounter('businesses', this.targetBusinesses, 1800);
      },
      animateCounter(prop, target, dur) {
        const t0 = performance.now();
        const step = (t) => {
          const p = Math.min((t - t0) / dur, 1);
          this[prop] = Math.floor((1 - Math.pow(1 - p, 3)) * target);
          if (p < 1) requestAnimationFrame(step); else this[prop] = target;
        };
        requestAnimationFrame(step);
      },
    };
  }
</script>
