---
// Need Provider Project Update v2.1
import Layout from '../layouts/Layout.astro';
/* Landing page v2.1 — Polished UI design system with refined ink color and spacing */
---

<Layout title="Rescue Surplus. Reduce Waste.">

  <!-- Panel 1: Hero -->
  <section class="relative min-h-screen bg-ink border-b-8 border-lime overflow-hidden flex items-center bg-grid-dark">

    <!-- Floating Doodles -->
    <div class="absolute top-24 right-12 text-lime/20 w-16 h-16 pointer-events-none animate-float-slow select-none hidden sm:block">
      <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
        <path d="M50 10 C50 35 35 50 10 50 C35 50 50 65 50 90 C50 65 65 50 90 50 C65 50 50 35 50 10 Z" />
      </svg>
    </div>
    <div class="absolute bottom-28 left-8 text-orange/20 w-12 h-12 pointer-events-none animate-spin-slow select-none hidden md:block">
      <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
        <path d="M50 15 L50 85 M15 50 L85 50 M25 25 L75 75 M25 75 L75 25" />
      </svg>
    </div>

    <div class="brutal-section py-20 relative z-10">
      <div class="max-w-4xl">
        <!-- Comic caption -->
        <div class="comic-caption mb-8 text-xs inline-block reveal">
          Chapter 1: The Crisis
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-tight mb-6 reveal" style="animation-delay:0.1s">
          Don't Let Good Food Go to Waste—<br />
          <span class="text-lime" style="-webkit-text-stroke:2px #ADFF2F; color:#ADFF2F">
            It Can Be
          </span><br />
          <span class="relative inline-block text-orange">
            Someone's Next Meal.
            <!-- Double hand-drawn underline doodle -->
            <svg class="absolute -bottom-3 left-0 w-full h-5 text-lime pointer-events-none" viewBox="0 0 300 20" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
              <path d="M5 12 C50 3, 150 18, 295 10" class="doodle-path" />
              <path d="M20 17 C80 6, 200 16, 280 9" class="doodle-path" opacity="0.7" />
            </svg>
          </span>
        </h1>

        <p class="text-xl sm:text-2xl text-gray-300 max-w-2xl mb-10 leading-relaxed reveal" style="animation-delay:0.2s">
          Don't let good food go to waste. Donate surplus food to help someone in need. Every meal shared reduces hunger and spreads kindness. Together, we can make a meaningful difference.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 reveal" style="animation-delay:0.3s">
          <button
            onclick="navigateTo(event, '/auth', '#ADFF2F')"
            class="brutal-btn text-lg px-8 py-4 text-xl font-black hover:animate-wobble"
          >
            Join the Solution
          </button>
          <button
            onclick="navigateTo(event, '/browse', '#FFD700')"
            class="brutal-btn-yellow text-lg px-8 py-4 text-xl font-black hover:animate-wobble"
          >
            Contribution HUB
          </button>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white text-center">
      <p class="text-xs font-black uppercase tracking-widest text-gray-400 mb-2">Scroll to see the story</p>
      <div class="w-8 h-12 border-4 border-gray-400 mx-auto flex items-start justify-center pt-2">
        <div class="w-2 h-3 bg-lime animate-bounce"></div>
      </div>
    </div>
  </section>

  <!-- Panel 2: Problem Statement -->
  <section class="relative min-h-screen bg-yellow border-b-8 border-ink overflow-hidden flex items-center bg-grid-light">
    <!-- Background spiral doodle -->
    <div class="absolute top-20 right-20 text-ink/5 w-24 h-24 pointer-events-none select-none hidden lg:block">
      <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M50 50 C40 40, 30 60, 50 70 C70 80, 80 40, 50 30 C20 20, 10 70, 50 90 C90 110, 110 30, 50 10" class="doodle-path" />
      </svg>
    </div>

    <div class="absolute top-0 left-0 bg-ink text-lime px-6 py-3 font-black text-sm uppercase tracking-widest border-r-4 border-b-4 border-ink">
      Chapter 2
    </div>

    <div class="brutal-section py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Illustration side -->
        <div class="text-center reveal order-last lg:order-first">
          <div class="relative inline-block">
            <div class="text-[10rem] sm:text-[14rem] animate-floatBob select-none font-black text-ink">E</div>
            <div class="speech-bubble absolute -top-4 -right-4 sm:-right-8 w-48 text-sm rotate-3 animate-bounceIn">
              "We have 200 loaves expiring TONIGHT!"
            </div>
            <!-- Hand-drawn Arrow pointing to the E -->
            <div class="absolute -bottom-10 -right-4 w-20 h-20 text-ink rotate-[15deg] pointer-events-none hidden sm:block">
              <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 20 C40 10, 80 30, 70 80" class="doodle-path" />
                <path d="M55 70 L70 80 L80 65" class="doodle-path" />
              </svg>
            </div>
          </div>
        </div>

        <!-- Text side -->
        <div class="reveal">
          <div class="comic-caption mb-6">Meanwhile, at a grocery store near you...</div>
          <h2 class="text-5xl sm:text-6xl font-black text-ink leading-none mb-6">
            Retailers are
            <span class="bg-orange text-white px-2 py-1 inline-block -rotate-1 relative mx-1">
              DROWNING
              <!-- Rough hand-drawn borders around DROWNING -->
              <svg class="absolute -inset-2 w-[calc(100%+16px)] h-[calc(100%+16px)] text-ink pointer-events-none" viewBox="0 0 100 40" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M3 3 L97 3 L97 37 L3 37 Z" class="doodle-path" />
              </svg>
            </span>
            in surplus.
          </h2>
          <p class="text-xl text-ink/80 leading-relaxed mb-6">
            Grocery stores, restaurants, furniture shops, and hotels sit on mountains of
            perfectly usable inventory — forced to <strong>throw it all away</strong> because
            they have no fast, affordable way to move it.
          </p>
          <div class="flex flex-wrap gap-3">
            <div class="brutal-card px-5 py-3 bg-white -rotate-1">
              <span class="font-black">Grocery</span>
            </div>
            <div class="brutal-card px-5 py-3 bg-white rotate-1">
              <span class="font-black">Restaurant</span>
            </div>
            <div class="brutal-card px-5 py-3 bg-white -rotate-1">
              <span class="font-black">Furniture</span>
            </div>
            <div class="brutal-card px-5 py-3 bg-white rotate-2">
              <span class="font-black">Hotel</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Panel 3: Solution -->
  <section class="relative min-h-screen bg-lime border-b-8 border-ink overflow-hidden flex items-center bg-grid-light">
    <div class="absolute top-0 left-0 bg-ink text-lime px-6 py-3 font-black text-sm uppercase tracking-widest border-r-4 border-b-4 border-ink">
      Chapter 3
    </div>

    <div class="brutal-section py-24 relative z-10">
      <div class="text-center max-w-4xl mx-auto">
        <div class="comic-caption mb-6 bg-ink text-lime reveal">
          Then... a hero appeared.
        </div>

        <!-- Huge hero logo stamp -->
        <div class="reveal mb-6 relative inline-block animate-float-slow" style="animation-delay:0.1s">
          <!-- Starburst radiating lines behind/around the N logo -->
          <svg class="absolute -inset-16 w-[calc(100%+128px)] h-[calc(100%+128px)] text-ink pointer-events-none select-none" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
            <path d="M30 30 L60 60" class="doodle-path" />
            <path d="M170 30 L140 60" class="doodle-path" />
            <path d="M30 170 L60 140" class="doodle-path" />
            <path d="M170 170 L140 140" class="doodle-path" />
            <path d="M10 100 L50 100" class="doodle-path" />
            <path d="M190 100 L150 100" class="doodle-path" />
            <path d="M100 10 L100 50" class="doodle-path" />
            <path d="M100 190 L100 150" class="doodle-path" />
          </svg>
          <div class="relative z-10 inline-block bg-ink border-4 border-ink p-8 shadow-brutal-xl -rotate-2 hover:rotate-0 transition-transform duration-300">
            <span class="text-8xl sm:text-[10rem] font-black text-white">N</span>
          </div>
        </div>

        <h2 class="text-6xl sm:text-8xl font-black text-ink leading-none mb-6 reveal" style="animation-delay:0.15s">
          Need Provider
          <br />
          <span class="relative inline-block text-white" style="-webkit-text-stroke:3px #0D0D0D">
            has entered
            <!-- Hand-drawn loop highlight -->
            <svg class="absolute -inset-x-2 -inset-y-1 w-[calc(100%+16px)] h-[calc(100%+8px)] text-ink pointer-events-none" viewBox="0 0 100 100" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M50 10 C20 10, 5 35, 10 60 C15 85, 45 95, 75 90 C95 85, 95 55, 90 35 C85 15, 60 8, 48 12" class="doodle-path" />
            </svg>
          </span>
          <br />
          the chat.
        </h2>

        <p class="text-xl sm:text-2xl text-ink/80 max-w-2xl mx-auto mb-8 leading-relaxed reveal" style="animation-delay:0.2s">
          Have something you no longer need? Donate food, clothes, books, or other useful items to people who need them most. Every small contribution creates a big impact.
        </p>

        <!-- Feature pills -->
        <div class="flex flex-wrap gap-4 justify-center reveal" style="animation-delay:0.25s">
          <div class="brutal-card px-5 py-3 bg-white font-black text-lg -rotate-1 hover:animate-wobble">Instant listing</div>
          <div class="brutal-card px-5 py-3 bg-white font-black text-lg rotate-1 hover:animate-wobble">Hyperlocal alerts</div>
          <div class="brutal-card px-5 py-3 bg-white font-black text-lg -rotate-2 hover:animate-wobble">Ultra-low prices</div>
          <div class="brutal-card px-5 py-3 bg-white font-black text-lg rotate-2 hover:animate-wobble">Zero backend</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Panel 4: Impact -->
  <section class="relative min-h-screen bg-pink border-b-8 border-ink overflow-hidden flex items-center bg-grid-light">
    <div class="absolute top-0 left-0 bg-ink text-pink px-6 py-3 font-black text-sm uppercase tracking-widest border-r-4 border-b-4 border-ink">
      Chapter 4
    </div>

    <div class="brutal-section py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Text side -->
        <div class="reveal">
          <div class="comic-caption mb-6 bg-white">
            Heroes on the other side...
          </div>
          <h2 class="text-5xl sm:text-6xl font-black text-ink leading-none mb-6 relative">
            NGOs swoop in
            <!-- Sketchy zigzag line -->
            <svg class="absolute bottom-10 left-0 w-64 h-6 text-ink pointer-events-none" viewBox="0 0 200 30" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 15 L40 5 L70 25 L100 5 L130 25 L160 5 L190 15" class="doodle-path" />
            </svg>
            <br />
            <span class="bg-ink text-pink px-2 py-1 inline-block rotate-1 mt-2">INSTANTLY.</span>
          </h2>
          <p class="text-xl text-ink/80 leading-relaxed mb-8">
            Community organizations get real-time alerts for surplus matching their needs.
            They claim resources, get a <strong>verification token</strong>, and collect —
            often within the hour. <strong>Zero waste. Zero waiting.</strong>
          </p>

          <!-- Steps -->
          <div class="space-y-4">
            <div class="brutal-card bg-white p-4 flex items-center gap-4 -rotate-1 reveal" style="animation-delay:0.1s">
              <div class="w-12 h-12 bg-ink text-white flex items-center justify-center font-black text-xl shrink-0">1</div>
              <div><strong>NGO gets notified</strong> when matching surplus appears nearby</div>
            </div>
            <div class="brutal-card bg-white p-4 flex items-center gap-4 rotate-1 reveal" style="animation-delay:0.2s">
              <div class="w-12 h-12 bg-lime border-4 border-ink flex items-center justify-center font-black text-xl shrink-0">2</div>
              <div><strong>Claims the resource</strong> with one click — no forms, no bureaucracy</div>
            </div>
            <div class="brutal-card bg-white p-4 flex items-center gap-4 -rotate-1 reveal" style="animation-delay:0.3s">
              <div class="w-12 h-12 bg-yellow border-4 border-ink flex items-center justify-center font-black text-xl shrink-0">3</div>
              <div><strong>Gets a token</strong> and collects from the retailer. Done!</div>
            </div>
          </div>
        </div>

        <div class="text-center reveal order-first lg:order-last">
          <div class="relative inline-block">
            <div class="text-[8rem] sm:text-[12rem] animate-floatBob font-black text-ink">N</div>
            <div class="speech-bubble absolute -top-8 -left-4 sm:-left-8 w-44 text-sm -rotate-2">
              "We got 50 families fed today!"
            </div>
            <div class="absolute -bottom-4 right-0 brutal-badge bg-lime text-ink font-black text-base px-4 py-2 rotate-3 hover:animate-wobble">
              +1,200 rescues!
            </div>
            <!-- Doodle Arrow pointing up to the badge -->
            <div class="absolute -bottom-16 right-12 w-16 h-16 text-ink pointer-events-none hidden sm:block">
              <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M30 90 Q40 50 10 30" class="doodle-path" />
                <path d="M10 50 L10 30 L30 20" class="doodle-path" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Panel 5: Stats -->
  <section class="relative bg-cyan border-b-8 border-ink overflow-hidden bg-grid-light">
    <!-- Floating background doodles -->
    <div class="absolute top-36 left-12 text-ink/10 w-20 h-10 pointer-events-none hidden lg:block">
      <svg viewBox="0 0 120 60" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
        <path d="M10 30 C30 10, 50 50, 70 30 C90 10, 110 50, 115 30" class="doodle-path" />
      </svg>
    </div>
    <div class="absolute bottom-20 right-12 text-ink/10 w-20 h-10 pointer-events-none hidden lg:block rotate-180">
      <svg viewBox="0 0 120 60" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
        <path d="M10 30 C30 10, 50 50, 70 30 C90 10, 110 50, 115 30" class="doodle-path" />
      </svg>
    </div>

    <div class="absolute top-0 left-0 bg-ink text-cyan px-6 py-3 font-black text-sm uppercase tracking-widest border-r-4 border-b-4 border-ink">
      Chapter 5
    </div>

    <!-- Ticker tape -->
    <div class="ticker-wrap py-3 mt-12">
      <div class="ticker-track">
        <span class="text-lime font-black text-lg mr-12 whitespace-nowrap">WASTE DIVERTED</span>
        <span class="text-yellow font-black text-lg mr-12 whitespace-nowrap">COMMUNITIES FED</span>
        <span class="text-pink font-black text-lg mr-12 whitespace-nowrap">RETAILERS SAVING MONEY</span>
        <span class="text-white font-black text-lg mr-12 whitespace-nowrap">REAL-TIME ALERTS</span>
        <span class="text-lime font-black text-lg mr-12 whitespace-nowrap">WASTE DIVERTED</span>
        <span class="text-yellow font-black text-lg mr-12 whitespace-nowrap">COMMUNITIES FED</span>
        <span class="text-pink font-black text-lg mr-12 whitespace-nowrap">RETAILERS SAVING MONEY</span>
        <span class="text-white font-black text-lg mr-12 whitespace-nowrap">REAL-TIME ALERTS</span>
      </div>
    </div>

    <div
      x-data="counterBanner()"
      x-init="init()"
      class="brutal-section py-16"
    >
      <div class="text-center mb-12 reveal">
        <div class="comic-caption bg-ink text-lime mb-4">The numbers don't lie</div>
        <h2 class="text-5xl sm:text-6xl font-black text-ink">The Impact So Far</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="brutal-card bg-lime p-8 text-center -rotate-1 hover:rotate-0 transition-transform reveal">
          <div class="text-5xl sm:text-6xl font-black text-ink mb-2">
            <span x-text="wasteDiverted.toLocaleString()">0</span><span class="text-3xl">lbs</span>
          </div>
          <div class="font-black uppercase text-sm tracking-wider">Waste Diverted</div>
        </div>
        <div class="brutal-card bg-yellow p-8 text-center rotate-1 hover:rotate-0 transition-transform reveal" style="animation-delay:0.1s">
          <div class="text-5xl sm:text-6xl font-black text-ink mb-2">
            <span x-text="activeListings">0</span>
          </div>
          <div class="font-black uppercase text-sm tracking-wider">Active Listings</div>
        </div>
        <div class="brutal-card bg-orange p-8 text-center -rotate-1 hover:rotate-0 transition-transform reveal" style="animation-delay:0.2s">
          <div class="text-5xl sm:text-6xl font-black text-white mb-2">
            <span x-text="businesses">0</span>
          </div>
          <div class="font-black uppercase text-sm tracking-wider text-white">Businesses</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Panel 6: Call to Action -->
  <section class="relative min-h-screen bg-ink border-b-8 border-lime overflow-hidden flex items-center bg-grid-dark">
    <!-- Background spiral doodle -->
    <div class="absolute top-24 right-16 text-lime/5 w-24 h-24 pointer-events-none select-none hidden lg:block">
      <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M50 50 C40 40, 30 60, 50 70 C70 80, 80 40, 50 30 C20 20, 10 70, 50 90 C90 110, 110 30, 50 10" class="doodle-path" />
      </svg>
    </div>

    <div class="absolute top-0 left-0 bg-lime text-ink px-6 py-3 font-black text-sm uppercase tracking-widest border-r-4 border-b-4 border-ink">
      Your Chapter
    </div>

    <div class="brutal-section py-24 relative z-10">
      <div class="text-center max-w-4xl mx-auto">
        <div class="comic-caption bg-lime text-ink mb-8 inline-block reveal">
          Now it's YOUR turn to be the hero.
        </div>

        <h2 class="text-5xl sm:text-7xl lg:text-8xl font-black text-white leading-none mb-6 reveal" style="animation-delay:0.1s">
          Write
          <span class="relative inline-block text-lime">
            your
            <!-- Hand-drawn loop highlight -->
            <svg class="absolute -inset-x-3 -inset-y-1 w-[calc(100%+24px)] h-[calc(100%+8px)] text-lime pointer-events-none" viewBox="0 0 100 100" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <path d="M50 10 C20 10, 5 35, 10 60 C15 85, 45 95, 75 90 C95 85, 95 55, 90 35 C85 15, 60 8, 48 12" class="doodle-path" />
            </svg>
          </span>
          <br />
          chapter.
        </h2>

        <p class="text-xl sm:text-2xl text-gray-300 max-w-2xl mx-auto mb-12 reveal" style="animation-delay:0.2s">
          Whether you're a <strong class="text-yellow">retailer</strong> sitting on surplus
          or an <strong class="text-pink">NGO</strong> looking to rescue resources —
          your story starts here.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto reveal" style="animation-delay:0.25s">
          <!-- Retailer CTA -->
          <button
            onclick="navigateTo(event, '/auth', '#ADFF2F')"
            class="brutal-card bg-lime p-8 text-center group cursor-pointer text-left hover:animate-wobble"
          >
            <div class="text-6xl mb-4 group-hover:scale-110 transition-transform font-black">🏪</div>
            <h3 class="text-2xl font-black text-ink mb-2">I'm a Retailer</h3>
            <p class="text-ink/70 text-sm mb-4">List surplus inventory in 60 seconds. Turn waste into impact.</p>
            <div class="brutal-btn text-sm inline-flex">Start Listing</div>
          </button>

          <!-- NGO CTA -->
          <button
            onclick="navigateTo(event, '/auth', '#FF6EC7')"
            class="brutal-card bg-pink p-8 text-center group cursor-pointer text-left hover:animate-wobble"
          >
            <div class="text-6xl mb-4 group-hover:scale-110 transition-transform font-black">🤝</div>
            <h3 class="text-2xl font-black text-ink mb-2">We're an NGO</h3>
            <p class="text-ink/70 text-sm mb-4">Find surplus near you. Rescue resources. Feed communities.</p>
            <div class="brutal-btn-yellow text-sm inline-flex">Start Rescuing</div>
          </button>
        </div>

        <!-- Browse link -->
        <div class="mt-8 reveal" style="animation-delay:0.3s">
          <button
            onclick="navigateTo(event, '/browse', '#7DF9FF')"
            class="text-gray-400 hover:text-lime font-black underline underline-offset-4 text-lg transition-colors bg-transparent border-none cursor-pointer"
          >
            Or just browse what's available now
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Grid -->
  <section class="bg-cream border-b-8 border-ink bg-grid-light">
    <div class="brutal-section py-16 sm:py-20">
      <h2 class="text-4xl sm:text-5xl font-black text-center mb-4 relative inline-block left-1/2 -translate-x-1/2">
        Browse by 
        <span class="bg-lime px-2 -rotate-1 inline-block relative mx-1">
          Category
          <!-- Rough hand-drawn border doodle around Category -->
          <svg class="absolute -inset-1.5 w-[calc(100%+12px)] h-[calc(100%+12px)] text-ink pointer-events-none" viewBox="0 0 100 40" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M3 3 L97 3 L97 37 L3 37 Z" class="doodle-path" />
          </svg>
        </span>
      </h2>
      <p class="text-center text-ink/60 mb-12 max-w-md mx-auto font-semibold">
        Explore surplus resources by type, rescued from businesses in your area.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        <button onclick="navigateTo(event,'/browse?category=clothes','#ADFF2F')"
          class="brutal-card p-8 text-center bg-white group hover:bg-lime cursor-pointer w-full reveal hover:animate-wobble">
          <h3 class="text-2xl font-black mb-2">Clothes</h3>
          <p class="text-ink/60 text-sm">Gently used clothes for all ages</p>
        </button>
        <button onclick="navigateTo(event,'/browse?category=shelter','#FFD700')"
          class="brutal-card p-8 text-center bg-white group hover:bg-yellow cursor-pointer w-full reveal hover:animate-wobble" style="animation-delay:0.1s">
          <h3 class="text-2xl font-black mb-2">Shelter</h3>
          <p class="text-ink/60 text-sm">Temporary housing & safety spaces</p>
        </button>
        <button onclick="navigateTo(event,'/browse?category=books','#7DF9FF')"
